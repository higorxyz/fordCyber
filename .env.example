# Security configuration (use strong values in production)
JWT_SECRET=change-me
DATA_ENCRYPTION_KEY=change-me
PAYLOAD_SIGNING_SECRET=change-me
# Local: http://localhost:3001
# Production (Vercel): https://seu-projeto.vercel.app
ALLOWED_ORIGINS=https://seu-projeto.vercel.app
APP_BASE_URL=https://seu-projeto.vercel.app
CRON_SECRET=change-me
MIN_TLS_VERSION=1.2
# Em Vercel normalmente use false (header de versão TLS pode não estar disponível)
REQUIRE_TLS_VERSION_HEADER=false
ALLOW_INSECURE_HTTP=false
EXTERNAL_SERVICE_URL=
EXTERNAL_SERVICE_TIMEOUT_MS=8000
DATABASE_URL=
DATABASE_SSL=true
DATABASE_MAX_CONNECTIONS=3
# Password reset
PASSWORD_RESET_TTL_MINUTES=20
# SMTP (reset de senha)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
# Produção recomendada: desativar credenciais demo e criar admin bootstrap
SEED_DEMO_USERS=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong
BOOTSTRAP_ADMIN_NAME=Administrador
