# Security configuration (use strong values in production)
JWT_SECRET=change-me
DATA_ENCRYPTION_KEY=change-me
PAYLOAD_SIGNING_SECRET=change-me
CRON_SECRET=change-me

# Origins and app URL
ALLOWED_ORIGINS=https://seu-projeto.vercel.app
APP_BASE_URL=https://seu-projeto.vercel.app

# Transport security
MIN_TLS_VERSION=1.2
REQUIRE_TLS_VERSION_HEADER=false
ALLOW_INSECURE_HTTP=false

# Database
DATABASE_URL=
DATABASE_SSL=true
DATABASE_MAX_CONNECTIONS=3

# External service
EXTERNAL_SERVICE_TIMEOUT_MS=8000

# Password reset
PASSWORD_RESET_TTL_MINUTES=20

# SMTP (password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Bootstrap / seed
SEED_DEMO_USERS=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong
BOOTSTRAP_ADMIN_NAME=Administrador
